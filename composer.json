{
    "name": "cboxdk/statamic-filter-builder",
    "description": "Build advanced collection filters and sort orders through the Statamic control panel.",
    "license": "MIT",
    "type": "statamic-addon",
    "keywords": [
        "statamic",
        "addon",
        "filter",
        "sort",
        "collection",
        "fieldtype"
    ],
    "authors": [
        {
            "name": "Sylvester Damgaard",
            "homepage": "https://github.com/cboxdk"
        }
    ],
    "homepage": "https://github.com/cboxdk/statamic-filter-builder",
    "support": {
        "issues": "https://github.com/cboxdk/statamic-filter-builder/issues"
    },
    "require": {
        "php": "^8.2",
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "conflict": {
        "tv2regionerne/statamic-filter-builder": "*"
    },
    "autoload": {
        "psr-4": {
            "Cbox\\FilterBuilder\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cbox\\FilterBuilder\\Tests\\": "tests"
        }
    },
    "extra": {
        "statamic": {
            "name": "Filter Builder",
            "description": "Build advanced collection filters and sort orders through the control panel."
        },
        "laravel": {
            "providers": [
                "Cbox\\FilterBuilder\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "lint": "./vendor/bin/pint --test",
        "fix": "./vendor/bin/pint",
        "analyse": "./vendor/bin/phpstan analyse --no-progress",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "pixelfear/composer-dist-plugin": false
        }
    }
}
